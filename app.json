{
  "expo": {
    "name": "NosGallery",
    "slug": "NosGallery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_vibrant.png",
    "scheme": "nosgallery",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nothing.nosgallery",
      "icon": "./assets/images/logo_vibrant.png"
    },
    "android": {
      "package": "com.nothing.nosgallery",
      "icon": "./assets/images/logo_vibrant.png",
      "adaptiveIcon": {
        "backgroundColor": "#080111",
        "foregroundImage": "./assets/images/logo_vibrant.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_vibrant.png"
    },
    "plugins": [
      "./modules/expo-widget/app.plugin.js",
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/logo_vibrant.png",
          "resizeMode": "cover",
          "android": {
            "image": "./assets/images/logo_vibrant.png",
            "resizeMode": "cover",
            "backgroundColor": "#000000"
          },
          "ios": {
            "image": "./assets/images/logo_vibrant.png",
            "resizeMode": "cover",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "07a67af3-c537-464d-b14d-d6f2e8e8a93f"
      }
    }
  }
}
