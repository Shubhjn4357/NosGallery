{
  "expo": {
    "name": "NosGallery",
    "slug": "NosGallery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_minimal_n.png",
    "scheme": "nosgallery",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nothing.nosgallery",
      "icon": "./assets/images/logo_minimal_n.png"
    },
    "android": {
      "package": "com.nothing.nosgallery",
      "icon": "./assets/images/logo_minimal_n.png",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_minimal_n.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/logo_minimal_n.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200,
            "backgroundColor": "#000000"
          },
          "ios": {
            "image": "./assets/images/logo_minimal_n.png",
            "imageWidth": 200,
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
