<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.expowidget">

    <application>
        <!-- Generic Size-Based Widgets -->
        <receiver
            android:name="com.nothing.nosgallery.widget.NOSWidget1x1"
            android:exported="true"
            android:label="NOS Widget 1x1">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.nothing.nosgallery.WIDGET_CLICK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widgetprovider_1x1" />
        </receiver>

